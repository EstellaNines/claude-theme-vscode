  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#87867F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#C46686"
      }
    },
    {
      "scope": ["string", "constant.other.symbol"],
      "settings": {
        "foreground": "#9CAF7E"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language", "variable.language"],
      "settings": {
        "foreground": "#CBCADB"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#D97757"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type"],
      "settings": {
        "foreground": "#6A9BCC"
      }
    },
    {
      "scope": ["variable", "meta.definition.variable.name", "entity.name.variable"],
      "settings": {
        "foreground": "#F5F4ED"
      }
    },
    {
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": {
        "foreground": "#D97757"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#E3DACC"
      }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": {
        "foreground": "#B0AEA5"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#BF4D43"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#6A9BCC",
    "enum": "#6A9BCC",
    "interface": "#6A9BCC",
    "struct": "#6A9BCC",
    "typeParameter": "#6A9BCC",
    "function": "#D97757",
    "method": "#D97757",
    "macro": "#D97757",
    "parameter": "#E8E6DC",
    "property": "#E8E6DC",
    "variable": "#F5F4ED",
    "enumMember": "#CBCADB",
    "keyword": "#C46686",
    "string": "#9CAF7E",
    "number": "#CBCADB",
    "operator": "#B0AEA5"
  }
}
