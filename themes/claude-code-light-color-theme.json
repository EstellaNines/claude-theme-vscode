    "menu.foreground": "#141413",
    "menu.selectionBackground": "#D9775720",
    "menu.selectionForeground": "#141413",
    "menu.border": "#DEDCD1",

    "peekView.border": "#D97757",
    "peekViewEditor.background": "#F5F4ED",
    "peekViewResult.background": "#F0EEE6",
    "peekViewTitle.background": "#E8E6DC",
    "peekViewTitleLabel.foreground": "#141413",

    "diffEditor.insertedTextBackground": "#788C5D26",
    "diffEditor.removedTextBackground": "#BF4D4320",
    "gitDecoration.addedResourceForeground": "#788C5D",
    "gitDecoration.modifiedResourceForeground": "#6A9BCC",
    "gitDecoration.deletedResourceForeground": "#BF4D43",
    "gitDecoration.untrackedResourceForeground": "#788C5D",
    "gitDecoration.ignoredResourceForeground": "#9C9A92"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#87867F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#C46686"
      }
    },
    {
      "scope": ["string", "constant.other.symbol"],
      "settings": {
        "foreground": "#788C5D"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language", "variable.language"],
      "settings": {
        "foreground": "#7C3AED"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#C46849"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type"],
      "settings": {
        "foreground": "#6A9BCC"
      }
    },
    {
      "scope": ["variable", "meta.definition.variable.name", "entity.name.variable"],
      "settings": {
        "foreground": "#30302E"
      }
    },
    {
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": {
        "foreground": "#C6613F"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#B45309"
      }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": {
        "foreground": "#73726C"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#BF4D43"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#6A9BCC",
    "enum": "#6A9BCC",
    "interface": "#6A9BCC",
    "struct": "#6A9BCC",
    "typeParameter": "#6A9BCC",
    "function": "#C46849",
    "method": "#C46849",
    "macro": "#C46849",
    "parameter": "#4D4C48",
    "property": "#4D4C48",
    "variable": "#30302E",
    "enumMember": "#7C3AED",
    "keyword": "#C46686",
    "string": "#788C5D",
    "number": "#7C3AED",
    "operator": "#73726C"
  }
}
